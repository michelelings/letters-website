# Copy to .env.local for vercel dev (never commit secrets).
# On Vercel: Project Settings → Environment Variables.

# Shared Google service account JSON (single line string). Needs:
# - GA4: Viewer on the GA4 property
# - GSC: added as a user on the Search Console property
GOOGLE_SERVICE_ACCOUNT_JSON=

# GA4 numeric property id (Admin → Property settings), not the measurement id.
GA4_PROPERTY_ID=

# Exact Search Console property URL (prefix and trailing slash must match the property).
GSC_SITE_URL=https://www.letters.game/

# Domain host for Ahrefs and Semrush (no protocol).
SITE_DOMAIN=letters.game

# Ahrefs API v3 bearer token (paid plan).
AHREFS_API_KEY=

# Semrush API key. Optional database slug (default us).
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us
